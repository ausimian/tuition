%%% rebar3-native build for the pure-Erlang Sonde terminal UI framework.
%%%
%%% This is the framework half of Sonde (PRD §12): terminal backends, input
%%% parser, diff renderer, layout engine, widgets and the multi-pane app shell —
%%% reusable by anyone building a BEAM TUI, observation or not. It targets zero
%%% dependencies beyond OTP and builds natively under *both* rebar3 and Mix, so
%%% an Erlang-only shop can embed it with no Elixir anywhere in the chain. Keep
%%% `deps' empty — the observer library (`sonde') depends on this, never the
%%% reverse.
{erl_opts, [debug_info, warnings_as_errors]}.

{deps, []}.

{eunit_opts, [verbose]}.

{xref_checks, [
    undefined_function_calls,
    deprecated_function_calls,
    locals_not_used
]}.

{dialyzer, [{warnings, [unknown]}]}.

%% Project-local formatter. `project_plugins' keeps erlfmt off consumers of
%% sonde_tui, so the zero-dependency embed guarantee (PRD §12) is unaffected —
%% it is pulled only when this project itself runs `rebar3 fmt' (directly, or via
%% the top-level `mix format' alias). Bench tooling stays profile-scoped below.
{project_plugins, [erlfmt]}.

{erlfmt, [
    {files, ["src/*.erl", "include/*.hrl", "test/*.erl"]}
]}.

{profiles, [
    {test, [{erl_opts, [nowarn_export_all]}]},
    %% `BENCH_GUARD' compiles in the bench_render_guard eunit entry point, so the
    %% perf-regression guard exists only under this profile — a plain `rebar3
    %% eunit' finds no timing test to run (and no rebar3_bench to fetch), keeping
    %% the default build path and the noisy timing check out of CI.
    {bench, [
        {plugins, [rebar3_bench]},
        {erl_opts, [{d, 'BENCH_GUARD'}]}
    ]}
]}.

%% `rebar3 as bench guard' runs the diff/2 perf-regression guard (issue #26) and
%% nothing else — a ratio-based timing assertion, not a benchmark report.
{alias, [{guard, [{eunit, "--module=bench_render_guard"}]}]}.
