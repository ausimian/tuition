%%% rebar3-native build for `tuition' — a pure-Erlang terminal UI framework:
%%% terminal backends, input parser, diff renderer, layout engine, widgets and
%%% the multi-pane app shell — reusable by anyone building a BEAM TUI,
%%% observation or not. It targets zero dependencies beyond OTP and builds
%%% natively under *both* rebar3 and Mix, so an Erlang-only shop can embed it
%%% with no Elixir anywhere in the chain. Keep `deps' empty.
{erl_opts, [debug_info, warnings_as_errors]}.

{deps, []}.

{eunit_opts, [verbose]}.

{xref_checks, [
    undefined_function_calls,
    deprecated_function_calls,
    locals_not_used
]}.

{dialyzer, [
    {warnings, [unknown]},
    {plt_extra_apps, [ssh]}
]}.

%% Project-local tooling. `project_plugins' keeps erlfmt and rebar3_ex_doc off
%% consumers of tuition, so the zero-dependency embed guarantee is unaffected —
%% they are pulled only when this project itself runs `rebar3 fmt' / `rebar3
%% ex_doc'. Bench tooling stays profile-scoped below.
{project_plugins, [erlfmt, rebar3_ex_doc]}.

{erlfmt, [
    {files, ["src/*.erl", "include/*.hrl", "test/*.erl"]}
]}.

%% ExDoc reads the OTP `-doc'/`-moduledoc' chunks the compiler emits from the
%% attributes in `src/*.erl' (issue #46), producing Elixir-standard HexDocs from
%% one source of prose — the same chunks `mix docs' consumes. `{hex, [{doc,
%% ex_doc}]}' makes `rebar3 hex publish docs' use ExDoc rather than edoc.
%% The `guides/*.md' extras are the narrative on-ramp (issue #55), grouped under
%% "Guides". The `notebooks/*.livemd' extras are the runnable per-widget showcases
%% (issue #56): ExDoc renders each as a docs page, copies the raw `.livemd'
%% alongside it, and adds the Run-in-Livebook badge itself — pointed at that copy,
%% resolved from the page's own URL, so a notebook carries no badge markup of its
%% own. Keep this list in step with `docs/0' in `mix.exs' — the two build systems
%% each carry their own copy.
{ex_doc, [
    {source_url, <<"https://github.com/ausimian/tuition">>},
    {extras, [
        <<"README.md">>,
        <<"guides/getting_started.md">>,
        <<"guides/programming_model.md">>,
        <<"guides/handling_input.md">>,
        <<"guides/building_widgets.md">>,
        <<"guides/terminal_backends.md">>,
        <<"notebooks/list.livemd">>,
        <<"LICENSE">>
    ]},
    {groups_for_extras, [
        {<<"Guides">>, [
            <<"guides/getting_started.md">>,
            <<"guides/programming_model.md">>,
            <<"guides/handling_input.md">>,
            <<"guides/building_widgets.md">>,
            <<"guides/terminal_backends.md">>
        ]},
        {<<"Widget showcases">>, [<<"notebooks/list.livemd">>]}
    ]},
    {main, <<"readme">>}
]}.

{hex, [{doc, ex_doc}]}.

{profiles, [
    {test, [{erl_opts, [nowarn_export_all]}]},
    %% `BENCH_GUARD' compiles in the bench_render_guard eunit entry point, so the
    %% perf-regression guard exists only under this profile — a plain `rebar3
    %% eunit' finds no timing test to run (and no rebar3_bench to fetch), keeping
    %% the default build path and the noisy timing check out of CI.
    {bench, [
        {plugins, [rebar3_bench]},
        {erl_opts, [{d, 'BENCH_GUARD'}]}
    ]}
]}.

%% `rebar3 as bench guard' runs the diff/2 perf-regression guard (issue #26) and
%% nothing else — a ratio-based timing assertion, not a benchmark report.
{alias, [{guard, [{eunit, "--module=bench_render_guard"}]}]}.
